# ONDEWO T2S NodeJS client — examples configuration template.
#
# Copy/keep this file next to the examples; each example loads it via dotenv
# (path is resolved relative to the script, so the working directory does not
# matter). This is a NON-SECRET template: fill the blank secrets locally and do
# NOT commit real credentials.

# --- Connection -------------------------------------------------------------
# Host and port of the ONDEWO T2S gRPC server.
ONDEWO_HOST=localhost
ONDEWO_PORT=50055

# --- Secure channel ---------------------------------------------------------
# Set ONDEWO_USE_SECURE_CHANNEL=true to use TLS. ONDEWO_GRPC_CERT is an optional
# path to a root/CA certificate file; leave blank to use the system trust store.
ONDEWO_USE_SECURE_CHANNEL=false
ONDEWO_GRPC_CERT=

# --- Keycloak (headless SDK: ROPC + offline_access) -------------------------
# Base Keycloak URL, realm and the PUBLIC SDK client id (no secret).
KEYCLOAK_URL=https://keycloak.example.com/auth
KEYCLOAK_REALM=ondewo
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
# Technical-user credentials for the ROPC login.
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak server's TLS certificate (set false only for self-signed).
KEYCLOAK_VERIFY_SSL=true

# --- T2S service-specific ---------------------------------------------------
# Id of the T2S pipeline that renders the audio.
ONDEWO_T2S_PIPELINE_ID=default_pipeline
